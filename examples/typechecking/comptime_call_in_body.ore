PICKED :: comptime if (true) 1 else 2


GOOD :: comptime if (true)
    42
else
    0

SWITCH :: comptime switch 3
    1 => 10
    2 => 20
    3 => 30

sum_to_n :: comptime fn(n: i32) i32
    total := 0
    loop (i := 100; i < n; i++)
        total = total + i
    total

X :: sum_to_n(50_000) 

square :: comptime fn(x: i32) i32
    x * x

main :: fn() i32
    square(7)
    0