math :: @import("./imports/import_math.ore")

Allocator :: scoped effect<s>
    alloc :: fn(comptime t: type, count: usize) -> []t

Buffer :: struct
    data : []u8

make_buffer :: fn(comptime s: Scope, count: usize) <Allocator(s) | e> -> Buffer
    Buffer.{ .data = alloc(u8, count) }

answer_box :: math.Number
