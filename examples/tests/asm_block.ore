/*
    Positive — inline asm block types as void. The lexer keeps the
    body verbatim; sema's type_from_lit_token gives SK_ASM_LIT a void
    type so the block can sit as a statement in a void-bodied fn.
    Exercises B3 (the 1-line addition in infer.c's type_from_lit_token).
*/

syscall_exit :: fn(code: i32) void
    ```
    mov x0, %[code]
    mov x16, #1
    svc #0x80
    ```

main :: pub fn() void
    syscall_exit(0)
