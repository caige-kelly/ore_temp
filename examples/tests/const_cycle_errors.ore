/*
    Phase J1 — circular const dependency detection.
    Pre-J1 these would stack-overflow `eval_ref`'s unbounded recursion.
    Post-J1 each must produce exactly one "circular const dependency"
    diagnostic and exit cleanly with rc != 0.
*/

// Direct self-reference.
SELF :: SELF

// Two-step mutual cycle.
A :: B
B :: A

// Three-step cycle.
X :: Y
Y :: Z
Z :: X

// A cycle hidden under arithmetic — eval_bin recurses through the RHS,
// hits eval_ref for the self-reference. Still detected because the
// stack tracks the binding, not just the leaf node.
WRAP :: WRAP + 1
