/*
    Stage E.2 — every binding here should produce a typecheck error.
*/

// Helper that exists so call-site errors below have something to call.
add :: fn(a: i32, b: i32) -> i32
    a + b

// Wrong arg count
bad_arity :: fn() -> i32
    add(10)

// Wrong arg type
bad_arg_type :: fn() -> i32
    add(10, true)

// Mismatched bin operands (concrete vs concrete)
bad_bin :: fn() -> i32
    1 + true

// Non-bool if condition
bad_if_cond :: fn() -> i32
    if (42) 1 else 2

// Non-numeric unary minus
bad_neg :: fn() -> bool
    -true

// Comptime overflow at call site
takes_u8 :: fn(x: u8) -> u8
    x

bad_call_overflow :: fn() -> u8
    takes_u8(1_000_000_000)
