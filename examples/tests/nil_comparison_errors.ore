/*
    nil comparison negative cases.

    Per the strict-nil model (§H of the array-init plan), `nil` only
    fits `?T`. Raw pointers, slices, and many-pointers reject nil in
    BOTH the coerce path (assigns) and the comparison path (==/!=).
*/

H :: struct
    next : ?^H

// Raw pointer cannot compare to nil — must wrap in `?` first.
raw_ptr_eq :: fn(h : ^H) bool
    h == nil                           // ERROR

raw_ptr_ne :: fn(h : ^H) bool
    h != nil                           // ERROR

// Slice / many-pointer cannot compare to nil.
slice_eq :: fn(s : []u8) bool
    s == nil                           // ERROR

many_ptr_ne :: fn(p : [^]u8) bool
    p != nil                           // ERROR

// Equality between two distinct non-comparable types.
mixed_types :: fn(a : i32, b : bool) bool
    a == b                             // ERROR
