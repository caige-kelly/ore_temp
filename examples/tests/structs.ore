/*
    Stage E.3 — struct types, field access, struct literals, anonymous
    unions. All cases below should typecheck cleanly with no
    diagnostics.
*/

// Plain struct (layout-based, newline-separated members)
Point :: struct
    x : i32
    y : i32

// Struct literal — `Type{ .field = value, ... }` is the canonical
// form. The parser disambiguates this from a trailing-lambda call
// (`Type { body }`) via 3-token lookahead on `Dot Identifier Equal`.
origin :: Point{ .x = 0, .y = 0 }
unit_x :: Point{ .x = 1, .y = 0 }

// Field access
dx :: fn(p: Point) i32
    p.x

dy :: fn(p: Point) i32
    p.y

// Field access nested in arithmetic; struct literal returned
shift :: fn(p: Point, by: i32) Point
    Point{ .x = p.x + by, .y = p.y + by }

// Recursive shape — exercises the identity-only TY_STRUCT cycle break
Node :: struct
    value : i32
    next  : ^Node

// C-style anonymous union member. `obj.i` and `obj.f` both reach into
// the same group; reading either one is a valid access.
Variant :: struct
    tag : u8
    union
        i : i32
        f : f32

read_int :: fn(v: Variant) i32
    v.i

read_float :: fn(v: Variant) f32
    v.f

// Initializing a Variant: tag is a standalone field; one union arm
// must be set. Setting `i` satisfies the union group.
make_int_variant :: fn(n: i32) Variant
    Variant{ .tag = 0, .i = n }
