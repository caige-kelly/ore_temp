/*
    nil coerce rules (post-§H strict-nil tightening).

    `nil` is the singleton "absent" literal; it now coerces ONLY to
    `?T` for any T. Raw pointers, many-pointers, and slices are
    non-null at the type level — nullability requires the explicit
    `?` wrapper. This aligns ore's coerce rules with Zig's safety
    model (the type system FORCES the user to acknowledge optional
    unwrapping before dereference).

    See optional_nil_errors.ore for the rejection cases this fixture
    used to test (raw `^T = nil`, `[^]T = nil`, `[]T = nil`).
*/

// nil into an optional parameter.
takes_optional :: fn(o: ?i32)  ?i32
    o

via_optional :: fn()  ?i32
    takes_optional(nil)

// nil into an optional pointer.
takes_optional_ptr :: fn(o: ?^i32)  void
    return

via_optional_ptr :: fn()  void
    takes_optional_ptr(nil)

// nil into an optional many-pointer.
takes_optional_many_ptr :: fn(o: ?[^]u8)  void
    return

via_optional_many_ptr :: fn()  void
    takes_optional_many_ptr(nil)

// nil into an optional slice.
takes_optional_slice :: fn(o: ?[]const u8)  void
    return

via_optional_slice :: fn()  void
    takes_optional_slice(nil)

// nil into an optional const pointer.
takes_optional_const_ptr :: fn(o: ?^const i32)  void
    return

via_optional_const_ptr :: fn()  void
    takes_optional_const_ptr(nil)

// Locally-bound optional-pointer can hold nil.
echo :: fn(x: i32)  i32
    p : ?^i32 = nil
    if (x > 0) x else 0
