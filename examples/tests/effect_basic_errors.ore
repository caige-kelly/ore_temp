/*
    Phase 6 — effect_basic_errors.
    Negative fixtures (each line below must emit a diag).
    Verifies the 4f signature gate fires when body row exceeds declared row.
*/

exn :: pub effect
    fail :: fn(msg: []const u8) i32

io :: pub effect
    log :: fn(msg: []const u8) i32

// 1. Pure-declared fn that performs an effect — body exceeds declared.
under_declared_pure :: pub fn() i32
    exn.fail("nope")

// 2. Declared <exn> but body also performs io.
under_declared_partial :: pub fn() <exn> i32
    io.log("uh oh")
    exn.fail("partial")

// 3. Unknown effect name in row syntax.
unknown_effect :: pub fn() <nonexistent> i32
    42

// 4. Unknown op on a known effect.
unknown_op :: pub fn() <exn> i32
    exn.no_such_op()
