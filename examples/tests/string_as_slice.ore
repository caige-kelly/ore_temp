/*
    PR 3 #7 — `string` reified as `[]const u8`. Pre-PR-3 it was an
    opaque TY_STRING primitive that didn't interop with slice ops.
    Now slice operations work, and the two type spellings are
    interchangeable.
*/

// String literal types as []const u8 (= `string`).
greeting :: "hello"

// A `string` parameter accepts a string literal.
takes_string :: fn(s: string)  usize
    s.len

// A `[]const u8` parameter accepts a string literal too — same type.
takes_slice :: fn(s: []const u8)  usize
    s.len

via_string :: fn()  usize
    takes_string(greeting)

via_slice :: fn()  usize
    takes_slice(greeting)

// `[]u8` (mutable) does NOT accept a string literal. (Negative cases
// live in string_as_slice_errors.ore.)

// Cross-direction: a `[]const u8` arg flows into a `string`-typed
// parameter and vice versa.
roundtrip_a :: fn(b: []const u8)  usize
    takes_string(b)

roundtrip_b :: fn(s: string)  usize
    takes_slice(s)
