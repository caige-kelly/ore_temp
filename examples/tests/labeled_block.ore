// labeled_block.ore — labeled block as a statement / expression.
//
// Slice 4B validation: parse_block accepts a leading `:label`, so
// labeled blocks like `:blk { ... }` are parseable wherever a regular
// block is. Slice 4C will add `break :label v` for value-yielding;
// for now we just test the parse + sema can see labeled blocks at all.

// Labeled block as a statement, just for the scope.
side_effects :: pub fn() void
    :setup {
        x := 1
        y := 2
    }
    return

// Labeled block nested inside a function.
inner_scope :: pub fn(a: i32) i32
    :outer {
        b := a + 1
    }
    return 0
