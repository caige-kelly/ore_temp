/*
    Phase B — return-statement enforcement positives. All cases here
    must typecheck cleanly.
*/

// Explicit return of the last expression (Zig-strict) — the canonical
// fn-body shape in ore.
add :: fn(a : i32, b : i32) i32
    return a + b

// Explicit return with a payload.
neg :: fn(x : i32) i32
    return -x

// Naked `return` in a void fn — guard-clause idiom. Must be accepted.
guard :: fn(b : bool) void
    if (b)
        return
    return

// Branchwise explicit returns (Zig-strict: block-tails do not yield,
// so each branch must `return` itself).
choose :: fn(b : bool) i32
    if (b)
        return 1
    else
        return 2

// Early return in one branch, explicit return on the trailing expr.
clamp :: fn(x : i32) i32
    if (x < 0)
        return 0
    return x

// Infinite loop with `return` inside — typed as noreturn, accepted
// against any non-void declared return.
spin_until_done :: fn() i32
    loop
        return 42

// Early-return followed by dead-code — the trailing stmt is unreachable
// but the block STILL terminates via the explicit `return`. Must not
// emit "control reaches end".
early_exit :: fn() i32
    return 100
    99
