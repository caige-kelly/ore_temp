/*
    Stage E.3.5b — compile-time builtins (@sizeOf, @alignOf, @TypeOf,
    @typeName, @intCast). All cases below should typecheck cleanly with
    no diagnostics.
*/

// @sizeOf(T) — returns comptime_int
i32_size :: @sizeOf(i32)

// @alignOf(T) — returns comptime_int
i32_align :: @alignOf(i32)

// @sizeOf with a user-defined struct type
Point :: struct
    x : i32
    y : i32

Test :: struct
    z : i32
    y : i32

point_size :: @sizeOf(Point)

// @TypeOf(x) — returns `type` (the kind of types)
i32_type :: @TypeOf(42)

// @typeName(T) — returns `string`
type_name :: @typeName(i32)

// @intCast(T, x) — explicit integer conversion; result type is T
narrow :: fn(big: u64) -> u8
    @intCast(u8, big)

// Mixing builtins with regular code
total :: @sizeOf(Point) + @sizeOf(i32)
