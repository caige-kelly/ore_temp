// Drift-check fixture — exercises four diag emit families. Used by
// tools/lsp_workload.c's scenario_drift_check: a Pass-1 collection,
// then prepend "// drift\n" (10 bytes, 1 newline), then a Pass-2
// collection. Each diag's resolved line must shift by exactly 1 with
// no column drift. A FILE_RAW anchor on a Phase-3.1-cacheable query
// will keep its byte_start frozen across the edit and surface as
// drift=yes; a DIAG_ANCHOR_BODY anchor re-resolves to the correct
// shifted line via the wrapper map.

clean :: pub fn() i32
    return 42

// FN_SIGNATURE error: unknown type. Owner: QUERY_FN_SIGNATURE.
bad_sig :: pub fn() NoSuchType
    return 0

// Body type mismatch — drives coerce_or_diag. Owner: QUERY_INFER_BODY.
bad_body :: pub fn() i32
    return "hello"

// Effect-row mismatch — body performs <exn> with declared pure. Drives
// the 4f soundness gate at infer.c:3171 (row_unify + span_of, lambda-node
// anchored). Owner: QUERY_INFER_BODY.
exn :: pub effect
    fail :: fn(msg: []const u8) i32

row_mismatch :: pub fn() i32
    exn.fail("nope")

// Effectful comptime call — drives const_eval's eval_call emit site at
// const_eval.c:eval_call. The narrowing `n : u8 = effectful()` forces
// coerce.c's range-check path to invoke db_const_eval on the effectful
// callee; eval_call sees a non-empty effect row and emits "comptime call
// to effectful 'X' (effects <Y>)". Owner: QUERY_INFER_BODY (coerce runs
// inside check_expr's INFER_BODY frame). This is the Fix B validation
// target — pre-Fix-B the diag would be FILE_RAW and drift on a sibling-
// prepend edit; post-Fix-B it must be BODY-anchored.
io :: pub effect
    log :: fn(msg: []const u8) i32

effectful :: pub fn() <io> i32
    io.log("ran")

narrow_misuse :: pub fn() i32
    n : u8 = effectful()
    n

// Trailing unused — kept as a regression baseline for the CHECK driver
// (always-fresh per db_check_namespace; remains drift=no).
MAX :: MAX
