/*
    PR 2 — `::` const-bind chains fold transitively. Each link
    references the prior one; the const-eval query recurses through
    the Ident → resolve → def_origin → bind.value path so the entire
    chain collapses to a single CONST_INT at each typed-bind site.

    Range-checks below verify the folded value really fit its target
    — direct coverage for the silent coerce hole closed by PR 2 (the
    pre-PR-2 path saw CONST_NONE here and accepted any target).
*/

MAX     :: 1024
HALF    :: MAX / 2          // 512
QUARTER :: HALF / 2          // 256
DIFF    :: MAX - HALF        // 512
PROD    :: HALF * 2          // 1024
SUM     :: MAX + HALF        // 1536
NEG     :: -MAX              // -1024

// Folded values must fit their declared range.
m  : u16 = MAX               // 1024 fits u16 (max 65535)
h  : u16 = HALF              // 512  fits u16
q  : i16 = QUARTER           // 256  fits i16 (max 32767)
d  : u16 = DIFF              // 512  fits u16
p  : u16 = PROD              // 1024 fits u16
n  : i32 = NEG               // -1024 fits i32

// Block-tail folding — the final expression's value is the block's.
BLK :: { x :: 7 ; x + 1 }
b  : u8 = BLK                // 8 fits u8

// If-folding with comptime condition — collapses to taken branch.
IF1 :: if (true) 100 else 9999    // 100 (else branch never folded)
IF2 :: if (false) 9999 else 50    // 50
i1 : u8 = IF1
i2 : u8 = IF2

// Switch over a comptime scrutinee — matches first arm.
SW1 :: switch (1)
    1 => 10
    2 => 20
    _ => 99
sw1 : u8 = SW1               // 10 fits u8
