/*
    Follow-ups #1 — noreturn-callee detection via db_lookup_node_type.

    A non-void fn whose body ends in a call to a `noreturn` callee
    (with no explicit `return X` after) must typecheck cleanly.
    Before the cache-peek path, the terminator pass could not
    consult the callee's type without re-typing it (which would
    re-accumulate the callee's effect row into ctx->body_effect_row
    and break row-poly soundness — the Phase B deferral reason).
    The cache-peek pass reads from the in-flight NodeTypeBuilder
    that check_expr populated; pure HashMap read, no compute, no
    effect accumulation.
*/

// Single-effect panic. An infinite loop satisfies the noreturn
// return type (loop with no break → IP_NORETURN_TYPE; noreturn
// coerces to any expected type, including noreturn itself).
panic :: pub fn(msg: []const u8) noreturn
    loop
        msg

// Non-void caller whose only path ends in `panic(...)`. The
// terminator pass sees the call's cached fn-type return is
// IP_NORETURN_TYPE and treats the call as a terminator — no
// "control reaches end of non-void function" diag.
must_panic :: pub fn() i32
    panic("unreachable")

// Sibling case: panic in one if-arm, return in the other.
// Both arms terminate; the if-expr terminates the body.
choose :: pub fn(x: bool) i32
    if (x) { return 0 } else { panic("never") }
