/*
    Range-loop / loop-capture error cases.
*/

// Stored Range value — not supported (range only lives INLINE in a
// loop header today).
stored_range :: fn() void
    r := 0..10                 // ERROR: range only legal inline in a loop header

// Capture requires a Range or Optional cond; plain bool with capture
// is rejected.
capture_on_bool_loop :: fn(b : bool) void
    loop (b) <x>               // ERROR: loop capture requires range or optional
        b

// Range bounds must be a common numeric type.
str_bound :: fn() void
    loop (0.."ten") <i>        // ERROR: bounds not a common numeric type
        i
