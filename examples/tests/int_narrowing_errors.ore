/*
    Phase H1.5 — narrowing without a comptime value is rejected, AND
    same-width sign changes (u32 → i32) are rejected too because they
    would lose representability for values ≥ 2^31. Each line below must
    produce a diagnostic.

    Mirrors Zig's coerce arm — runtime narrowing requires @intCast.
*/

// Runtime narrow with no const value fails. The Zig-parity diag is
// "expected type 'u8', found 'u16'".
narrow_runtime :: fn(x: u16) u8
    x

// Same-width sign change fails — u32 has values (>= 2^31) that
// don't fit in i32, so Zig (and ore H1.5) reject this without a
// const-value proof.
same_width_sign_change :: fn(x: u32) i32
    x

// Comptime literal that exceeds the target's range. F1 already
// caught this; H1.5 preserves the diag wording (H3 Zig parity).
oversize_literal : u8 = 1024
