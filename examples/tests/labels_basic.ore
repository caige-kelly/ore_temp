// labels_basic.ore — labeled loops + labeled break / continue.
//
// Validates Slice 4A (SK_LABEL lexer rule: `:` immediately followed by
// an identifier with no whitespace lexes as a single SK_LABEL token) and
// Slice 4B (parse_body recognizes leading SK_LABEL on blocks; parse_block
// consumes the label as a token child of SK_BLOCK_STMT).
//
// Uses only ore's current loop forms: infinite `loop` and while-style
// `loop (cond)`. C-style for loops were removed.

// Labeled break across nested infinite loops.
find_first :: pub fn(haystack: [][]i32, needle: i32) i32
    i := 0
    loop :outer
        if (i >= haystack.len)
            break
        j := 0
        loop
            if (j >= haystack[i].len)
                break
            if (haystack[i][j] == needle)
                break :outer
            j += 1
        i += 1
    return -1

// Labeled continue: skip to the next outer iteration.
sum_nonneg :: pub fn(rows: [][]i32) i32
    total : i32 = 0
    i := 0
    loop :outer
        if (i >= rows.len)
            break
        j := 0
        loop
            if (j >= rows[i].len)
                break
            if (rows[i][j] < 0)
                i += 1
                continue :outer
            total += rows[i][j]
            j += 1
        i += 1
    return total

// While-style loop with a label.
count_up :: pub fn(limit: i32) i32
    n := 0
    loop :w (n < limit)
        n += 1
    return n

// Unlabeled break inside a labeled loop — still targets the innermost.
contains :: pub fn(arr: []i32, x: i32) bool
    i := 0
    loop :scan
        if (i >= arr.len)
            break :scan
        if (arr[i] == x)
            return true
        i += 1
    return false
