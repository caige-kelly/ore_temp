/*
    PR 3 #9 + B18 — pointer arithmetic and comparison restrictions.
    Single pointers, slices, ptr+ptr, mismatched elem types, and ptr
    ordering are all rejected.
*/

// Single pointer arithmetic — rejected. Single ptrs don't have
// length-erasure semantics that arithmetic needs.
single_ptr_add :: fn(p: ^u8, n: usize)  ^u8
    p + n

// Slice arithmetic — rejected for the same reason (slices have
// bounds; advancing one would require a new length too).
slice_add :: fn(s: []u8, n: usize)  []u8
    s + n

// Many-pointer with non-integer right operand.
many_ptr_plus_bool :: fn(p: [^]u8, b: bool)  [^]u8
    p + b

// `[^]T + [^]T` — adding two pointers is mathematically meaningless.
// Only `-` is defined between pointers.
ptr_plus_ptr :: fn(a: [^]u8, b: [^]u8)  [^]u8
    a + b

// Mismatched element types in pointer subtraction. Both sides must
// have the same interned pointer type — same elem AND same constness.
ptr_diff_elem_mismatch :: fn(a: [^]u8, b: [^]i32)  usize
    a - b

// Mismatched constness in pointer subtraction. `[^]u8` and `[^]const u8`
// intern to distinct Type*s, so they don't match.
ptr_diff_const_mismatch :: fn(a: [^]u8, b: [^]const u8)  usize
    a - b

// Pointer ordering is rejected. Only equality is well-defined for
// raw pointers — ordering would require knowing both pointers come
// from the same allocation, which we can't verify statically. Same
// policy as Zig (zig/src/Type.zig:340).
ptr_lt :: fn(a: [^]u8, b: [^]u8)  bool
    a < b

ptr_gte :: fn(a: [^]u8, b: [^]u8)  bool
    a >= b

// Single-pointer subtraction is rejected. Even though Zig allows it
// for *T, the semantics are confusing (the Zig source itself flags it
// as "weird" — see Sema.zig:14928-14938). Ore restricts subtraction
// to many-pointers.
single_ptr_diff :: fn(a: ^u8, b: ^u8)  usize
    a - b
