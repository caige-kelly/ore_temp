/*
    PR 2 — if / switch / block tail folding. With a comptime
    condition or scrutinee, query_const_eval collapses to the taken
    branch's value. This was previously CONST_NONE for any branching
    shape; range-checks on the result silently passed.
*/

// If: comptime condition collapses to the chosen branch.
TRUE_VAL  :: if (true)  10  else 9999
FALSE_VAL :: if (false) 9999 else 20

// Range-check confirms TRUE_VAL really is 10 (not 9999, which
// wouldn't fit u8).
a : u8 = TRUE_VAL    // 10 fits u8
b : u8 = FALSE_VAL   // 20 fits u8

// Switch: comptime scrutinee collapses to the matching arm.
PICK_1 :: switch (1)
    1 => 11
    2 => 22
    _ => 99
PICK_2 :: switch (2)
    1 => 11
    2 => 22
    _ => 99
PICK_OTHER :: switch (7)
    1 => 11
    2 => 22
    _ => 33

c : u8 = PICK_1       // 11
d : u8 = PICK_2       // 22
e : u8 = PICK_OTHER   // 33

// Block tail: the value of the last non-binding expression. Idents
// referencing in-block consts resolve through the local DefId then
// recurse via the Ident folding case.
BLK_LIT :: { 42 }
BLK_REF :: { x :: 7 ; x + 1 }

f : u8 = BLK_LIT     // 42
g : u8 = BLK_REF     // 8

// Runtime-condition `if` inside a fn body — the if expression's
// type is the join of the branches; const_eval returns CONST_NONE
// because the condition is a fn call, so coerce takes its
// structural-accept path. This is correct behavior, not a fold.
runtime :: fn()  bool
    true

maybe :: fn()  i32
    if (runtime()) 1 else 0
