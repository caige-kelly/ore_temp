/*
    Phase H1.5 — concrete-int width-change. Zig allows lossless
    widening between same-sign int types, AND from small-unsigned to
    strictly-wider-signed (since the unsigned range fits inside the
    larger signed range). Pre-H1.5 every same-class width change was
    rejected as a structural mismatch.

    All lines below must compile cleanly. Mirrors zig/src/Sema.zig's
    coerce arm for "intcast: same-sign-wider OR small-unsigned-to-
    wider-signed" (Sema.zig:28897-28905).
*/

// Unsigned widening: u8 → u16/u32/u64.
take_u16 :: fn(x: u16) u16
    return x

take_u32 :: fn(x: u32) u32
    return x

take_u64 :: fn(x: u64) u64
    return x

widen_u8_to_u16 :: fn(x: u8) u16
    return take_u16(x)

widen_u8_to_u32 :: fn(x: u8) u32
    return take_u32(x)

widen_u8_to_u64 :: fn(x: u8) u64
    return take_u64(x)

// Signed widening: i8 → i16/i32/i64.
take_i32 :: fn(x: i32) i32
    return x

widen_i8_to_i32 :: fn(x: i8) i32
    return take_i32(x)

// Small-unsigned → wider-signed: u8 → i16 / i32 / i64.
// u8's range [0,255] fits inside i16's [-32768, 32767], so this is
// lossless and Zig accepts it. Same-width unsigned → signed
// (u32 → i32) is rejected separately — see int_narrowing_errors.
widen_u8_to_i16 :: fn(x: u8) i16
    return x

widen_u8_to_i32 :: fn(x: u8) i32
    return take_i32(x)

// Comptime-int literals continue to narrow with range check. This
// is the F1 path; H1.5 doesn't disturb it.
literal_to_u8 : u8 = 200
literal_to_i16 : i16 = -200
