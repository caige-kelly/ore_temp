/*
    PR 3 #8 — function types in type position. `fn(...) -> T` is now
    a valid type expression, so higher-order functions can declare
    callback parameters and return-typed callbacks.

    Pre-PR-3 this errored with "type expressions of this shape are
    not yet supported."
*/

// Higher-order function: takes a 0-arg fn returning i32, calls it.
do_thrice :: fn(action: fn() -> i32) -> i32
    action() + action() + action()

// Two-arg callback parameter.
combine :: fn(x: i32, y: i32, op: fn(i32, i32) -> i32) -> i32
    op(x, y)

// Returning a function value typed via fn-in-type-position.
get_doubler :: fn() -> fn(i32) -> i32
    double

// The function we'll return.
double :: fn(x: i32) -> i32
    x + x

// Calling it. Note: `f := get_doubler()` (runtime bind) is needed
// here because the call result isn't comptime — `::` would error.
go :: fn() -> i32
    f := get_doubler()
    f(21)

// Annotated form (`name: T`) for fn-type params.
double_args :: fn(a: i32, b: i32) -> i32
    a + b

apply_combine :: fn(op: fn(a: i32, b: i32) -> i32) -> i32
    op(2, 3)
