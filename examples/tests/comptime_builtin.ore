/*
    PR 2 — @sizeOf / @alignOf fold to a real CONST_INT for primitive
    operands so coerce can range-check the result. Aggregate sizes
    (struct/array/enum) still fall back to CONST_NONE because the
    layout query lands in PR 2.5; they remain "structurally accept
    any target" until then. Document that gap inline.
*/

S_U8     :: @sizeOf(u8)
S_U16    :: @sizeOf(u16)
S_U32    :: @sizeOf(u32)
S_U64    :: @sizeOf(u64)
S_I32    :: @sizeOf(i32)
S_F64    :: @sizeOf(f64)
S_BOOL   :: @sizeOf(bool)

A_U32    :: @alignOf(u32)
A_F64    :: @alignOf(f64)

// All folded values fit u16 trivially.
a : u16 = S_U8       // 1
b : u16 = S_U16      // 2
c : u16 = S_U32      // 4
d : u16 = S_U64      // 8
e : u16 = S_I32      // 4
f : u16 = S_F64      // 8
g : u16 = S_BOOL     // 1
h : u16 = A_U32      // 4
i : u16 = A_F64      // 8

// Arithmetic on folded primitives — still folds.
combo  :: @sizeOf(u32) + @sizeOf(u8)   // 4 + 1 = 5
j : u8 = combo                          // 5 fits u8

// Aggregate @sizeOf — known partial. Pre-PR-2 silently accepted any
// target because const_eval returned CONST_NONE for @sizeOf entirely.
// PR 2 still returns CONST_NONE here (no layout query), so the
// behaviour is unchanged for this case; PR 2.5 will close it.
Point :: struct
    x : i32
    y : i32
agg_sz :: @sizeOf(Point)
// `agg : u8 = agg_sz` would fall through coerce's structural-accept
// branch — neither error nor verified. Don't include it as a typed
// bind in this fixture (would mask PR 2.5's regression).
