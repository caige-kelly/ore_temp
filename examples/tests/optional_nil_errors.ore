/*
    nil rejects at non-nullable coerce boundaries (post-§H strict-nil
    tightening). `nil` is *only* compatible with optionals (`?T`).
    Scalars, structs, enums, bool, AND raw pointers / slices /
    many-pointers must all reject it.
*/

takes_int :: fn(x: i32)  void
    return

takes_u8 :: fn(x: u8)  void
    return

takes_bool :: fn(b: bool)  void
    return

takes_float :: fn(f: f64)  void
    return

bad_int :: fn()  void
    takes_int(nil)

bad_u8 :: fn()  void
    takes_u8(nil)

bad_bool :: fn()  void
    takes_bool(nil)

bad_float :: fn()  void
    takes_float(nil)

// Struct-typed parameter rejects nil. Use the struct constructor or
// pass a pointer / optional if "absent" is meaningful.
Point :: struct
    x : i32
    y : i32

takes_point :: fn(p: Point)  void
    return

bad_point :: fn()  void
    takes_point(nil)

// §H — raw pointer, many-pointer, slice all reject nil now.
// Each previously coerced; the tightening makes them require `?` wrappers.
takes_ptr :: fn(p: ^i32)  void
    return
bad_raw_ptr :: fn()  void
    takes_ptr(nil)

takes_many_ptr :: fn(p: [^]u8)  void
    return
bad_many_ptr :: fn()  void
    takes_many_ptr(nil)

takes_slice :: fn(s: []const u8)  void
    return
bad_slice :: fn()  void
    takes_slice(nil)

takes_const_ptr :: fn(p: ^const i32)  void
    return
bad_const_ptr :: fn()  void
    takes_const_ptr(nil)

// Local typed binding of raw pointer to nil — also rejected now.
local_nil_raw_ptr :: fn()  void
    p : ^i32 = nil
    return

