/*
    PR 3.5 #B15 — nil rejects at non-nullable coerce boundaries.
    `nil` is *only* compatible with optionals (`?T`) and pointer-like
    targets (`^T`, `[^]T`, `[]T`). Scalars, structs, enums, and bool
    must all reject it.
*/

takes_int :: fn(x: i32) -> void
    void

takes_u8 :: fn(x: u8) -> void
    void

takes_bool :: fn(b: bool) -> void
    void

takes_float :: fn(f: f64) -> void
    void

bad_int :: fn() -> void
    takes_int(nil)

bad_u8 :: fn() -> void
    takes_u8(nil)

bad_bool :: fn() -> void
    takes_bool(nil)

bad_float :: fn() -> void
    takes_float(nil)

// Struct-typed parameter rejects nil. Use the struct constructor or
// pass a pointer / optional if "absent" is meaningful.
Point :: struct
    x : i32
    y : i32

takes_point :: fn(p: Point) -> void
    void

bad_point :: fn() -> void
    takes_point(nil)
