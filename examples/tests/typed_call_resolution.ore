/*
    Regression: a function call to a top-level fn resolves the callee via
    resolve_value_path's namespace-scope fallback (body scope misses, falls
    through to db_query_resolve_ref on the namespace's internal scope, and
    db_query_type_of_def returns the fn type). Param visibility in body and
    if-condition visibility over body locals are exercised here too.
*/

f :: fn(a: i32) i32
    return a

g :: fn(b: bool) i32
    x := b
    if (x)
        return f(1)
    else
        return f(0)

main :: fn() i32
    return g(true)
