/*
    Array-init shorthands (Array-init §A–§E). All cases below should
    typecheck cleanly with no diagnostics.

    Three forms:
      [N]T{}        -- recursive type-default fill
      [N]T{x...}    -- broadcast x across all N slots
      [N]T{a,b,c}   -- exact-count match (existing behavior)

    Plus one special coerce for string → fixed [N]u8 buffer.
*/

Header :: pub struct
    size : u32
    next : ?^Header

// {} — empty literal fills with type's default.
zeros    :: [5]i32{}                  // all 0
falses   :: [3]bool{}                 // all false
matrix   :: [3][3]u8{}                // recursive default → all zeros

// {x...} — broadcast.
fives    :: [5]i32{ 42... }
nils_arr :: [10]?^i32{ nil... }
bools    :: [4]bool{ true... }
bins     :: [100]?^Header{ nil... }   // the allocator pattern

// Exact-count match (existing behavior unchanged).
mixed    :: [5]i32{1, 2, 3, 4, 5}
bin1     :: [1]i32{42}                // 1-elem literal, NOT broadcast
infer1   :: [_]i32{99}                // size inference → [1]i32

// §E — string literal → fixed [N]u8 buffer.
debug_nm : [32]u8 = "init"            // 4-byte string, 28 zero pad
exact    : [4]u8 = "test"             // N == L: exact fit, no null term

// Multi-dim string compose (free from §E + array-elem coerce).
commands : [2][10]u8 = [2][10]u8{ "help", "exit" }
