/*
    Stage E.2 — function types, body checking, calls.
    All cases below should typecheck cleanly with no diagnostics.
*/

// Simple function with i32 args + return
add :: fn(a: i32, b: i32) i32
    return a + b

// Function with no args, comptime return
constant_42 :: fn() i32
    return 42

// Negation
negate :: fn(x: i32) i32
    return -x

// Bool + comparison
is_positive :: fn(x: i32) bool
    return x > 0

// Bin arithmetic mixing comptime + concrete
double :: fn(x: i32) i32
    return x * 2

// Calls — direct and nested
sum_three :: fn(a: i32, b: i32, c: i32) i32
    return add(add(a, b), c)

// Comptime literal coercion at the call site
twenty_one :: fn() i32
    return add(10, 11)
