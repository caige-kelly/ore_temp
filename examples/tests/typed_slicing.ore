/*
    Stage E.3.5c — slicing operations on arrays and slices. All cases
    below should typecheck cleanly with no diagnostics.
*/

// Slicing an array with comptime bounds → ^[N]T (pointer to array of
// known length, mirrors Zig's `*[N]T` for compile-time-known slices)
sub_arr :: fn(arr: [10]i32) ^[3]i32
    return arr[2..5]

// Slicing with runtime bounds → []T
window :: fn(buf: []u8, lo: usize, hi: usize) []u8
    return buf[lo..hi]

// Open-ended right form `arr[start..]` — comptime start + comptime
// array length → still ^[N]T
tail :: fn(arr: [10]i32) ^[7]i32
    return arr[3..]

// Open-ended right with runtime start → []T (no comptime length)
runtime_tail :: fn(arr: [10]i32, start: usize) []i32
    return arr[start..]

// Open-ended left form `arr[..end]` — comptime end + implicit
// start=0 → ^[end]T
prefix :: fn(arr: [10]i32) ^[4]i32
    return arr[0..4]

// Slicing a slice with runtime bounds → []T
reslice :: fn(s: []u8, n: usize) []u8
    return s[0..n]

// Indexing still works (single-element access, not slicing)
first :: fn(arr: [10]i32) i32
    return arr[0]
