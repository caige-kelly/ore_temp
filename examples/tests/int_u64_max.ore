/*
    Phase J2 — comptime int representation must cover the full u64
    range (0 .. 2^64 - 1). Pre-J2 any literal > INT64_MAX (2^63 - 1)
    was stored as a negative int64_t and fits_in rejected it for any
    unsigned target. Each line below must compile cleanly.
*/

// 2^63 — first value that didn't fit in i64.
boundary : u64 = 9223372036854775808

// 2^64 - 1 — u64 max.
max_u64  : u64 = 18446744073709551615

// Hex form, same value.
max_u64_hex : u64 = 0xFFFFFFFFFFFFFFFF

// Negative literal still works for signed targets — is_unsigned is
// cleared by the unary-minus path.
neg_max : i64 = -9223372036854775807

// Unsigned narrowing fits when the value fits.
narrow_ok : u8 = 200
