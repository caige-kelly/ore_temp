/*
    Phase 6 — effect_basic.
    Effect decl + op call from a fn declaring the same effect → clean compile.
    Multi-perform union: a fn that calls two ops from distinct effects
    declares <exn, io> and typechecks. Direct exercise of Phase 4c
    (row_union accumulator) + Phase 4f (signature gate).
*/

exn :: pub effect
    fail :: fn(msg: []const u8) i32

io :: pub effect
    log :: fn(msg: []const u8) i32

// Single effect.
single :: pub fn() <exn> i32
    exn.fail("boom")

// Multi-effect union (Phase 4c gate 1 OK case).
multi :: pub fn() <exn, io> i32
    io.log("first")
    exn.fail("second")

// Pure-by-default: no effect row is `<>`, body is pure.
pure_calc :: pub fn(x: i32) i32
    x * 2

// Same-effect chain — second call's effect already in row, no duplication.
chain :: pub fn(s: []const u8) <exn> i32
    exn.fail(s)
    exn.fail(s)
