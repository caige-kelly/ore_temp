/*
    nil comparison against optionals (?T) — symmetric in operand order.
    Required by the strict-nil model: coerce.c admits `nil → ?T` in
    assigns, so the equality path must agree.

    Raw pointers / slices / many-pointers are NOT eligible — only `?T`.
    The negative cases live in nil_comparison_errors.ore.
*/

H :: struct
    size : u32
    next : ?^H

// ?^T eq/ne nil — both directions.
eq_lhs :: fn(h : ?^H) bool
    return h == nil

eq_rhs :: fn(h : ?^H) bool
    return nil == h

ne_lhs :: fn(h : ?^H) bool
    return h != nil

ne_rhs :: fn(h : ?^H) bool
    return nil != h

// ?T (non-pointer) eq/ne nil.
opt_int_eq :: fn(o : ?i32) bool
    return o == nil

opt_int_ne :: fn(o : ?i32) bool
    return o != nil

// In a guard-clause position — paired with the capture syntax.
guard :: fn(h : ?^H) u32
    if (h != nil)
        return 0
    else
        return 99
