/*
    Phase B — return-statement enforcement negatives. Each fn here
    must emit at least one diagnostic.
*/

// `return;` (no payload) in a non-void fn — hard error.
naked_return_nonvoid :: fn() i32
    return                             // ERROR: requires a value

// `return X;` in a void fn — type mismatch via existing check_expr.
return_in_void :: fn() void
    return 42                          // ERROR: expected void, found i32

// Drop-off-end non-void fn — the terminator gate fires.
drop_off_end :: fn() i32
    x := 5                             // x is a let-bind statement
                                       // (void-typed); fn declared i32
                                       // → "control reaches end"

// if without else in a non-void fn — the else branch falls through.
if_no_else :: fn(b : bool) i32
    if (b)
        return 1
    // ERROR: control reaches end (else path drops off)

// Loop with break in a non-void fn — the break path falls through.
loop_falls_through :: fn(n : i32) i32
    i := 0
    loop
        if (i >= n) break
        i = i + 1
    // ERROR: loop fell through; expected i32, found void
