/*
    PR 3.5 #R5 — layout query rejects by-value cycles with a precise
    diagnostic, and folded aggregate sizes that overflow a target
    type fire the existing fits_in range-check.
*/

// By-value cycle — direct.
Bad :: struct
    self : Bad

bad_size : usize = @sizeOf(Bad)

// By-value cycle — transitive (Bad → Mid → Bad).
Mid :: struct
    inner : End

End :: struct
    back : Mid

mid_size : usize = @sizeOf(Mid)

// Folded size overflows a too-small target.
Big :: struct
    a : [1024]u8
    b : [1024]u8

// 2048 bytes; doesn't fit u8 (max 255). The whole point of R5 is
// that this now fires — pre-R5, @sizeOf(Big) returned CONST_NONE
// and coerce structurally accepted any target.
overflow : u8 = @sizeOf(Big)
