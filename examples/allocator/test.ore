allocator :: @import("./allocator.ore")
a :: allocator.Allocator

foo :: struct 
  hello : []const u8

main :: pub fn() i32
    comptime if (@build.mode == .debug)
        with allocator.debug
    else  
        with allocator.release

    r1 := a.alloc(u8, 1024)
    defer a.free(r1)

    _ = foo.hello


    return 0