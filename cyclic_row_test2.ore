/*
    Strategy B variant: nested Fn types where row vars at different
    levels might unify in a way that produces a cycle.
*/

io :: pub effect
    log :: fn(msg: []const u8) i32

apply :: pub fn(f: Fn() <..e> i32) <..e> i32
    f()

// outer ..e applied to inner fn whose row also has ..e — passed via param.
// `g` is itself Fn(Fn() <..e> i32) <..e> i32 — same as apply.
// At call `g(f)` inside, unification of g's expected param Fn() <..e>
// with f's type Fn() <..e> happens — both same e via name scope.
selfish :: pub fn(g: Fn(Fn() <..e> i32) <..e> i32, f: Fn() <..e> i32) <..e> i32
    g(f)
