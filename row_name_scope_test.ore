// Verification fixture for the named-row-variable name-scope fix.
//
// In `apply :: pub fn(f: fn() <..e> i32) <..e> i32`, both `..e`
// MUST intern the same IPK_ROW_VAR so the input row var propagates
// into the return row. Without the fix, each `..e` is a fresh row
// var and `call_with_io` fails to typecheck with:
//   "function declares <io> but body performs <IP[N]>"
// because the inferred row from the call doesn't unify with the
// outer fn's declared row.

exn :: pub effect
    fail :: fn(msg: []const u8) i32

io :: pub effect
    log :: fn(msg: []const u8) i32

apply :: pub fn(f: Fn() <..e> i32) <..e> i32 {
    f()
}

call_with_io :: pub fn() <io> i32 {
    apply(fn() <io> i32 { io.log("hi") })
}
