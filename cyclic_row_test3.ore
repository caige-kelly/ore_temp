/*
    Strategy C: a function calls itself with a fn arg that references its
    own row var. Recursive polymorphic with row-poly param.
*/

io :: pub effect
    log :: fn(msg: []const u8) i32

// Recursive: rec passes itself (a fn of the same shape) as f's body's type
// is Fn() <..e> i32. But we have an outer fn taking Fn() <..e> i32. If we
// call rec(rec), it would expect rec to be Fn() <..e> i32 — but rec is
// Fn(Fn(...)) <..e> i32 — won't typecheck, but might trigger the cycle path
// before that check completes.
apply :: pub fn(f: Fn() <..e> i32) <..e> i32
    f()

// Try direct: apply(apply) — apply is Fn(Fn() <..e> i32) <..e> i32.
// Param expected: Fn() <..e> i32 (zero args). Mismatched param count
// might be caught structurally before row unification.
mistake :: pub fn() i32
    apply(apply)
